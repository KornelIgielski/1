package com.company;
 
public class Point {
    private int x, y;
    private String name;
 
    Point(String name, int x, int y) {
        this.x = x;
        this.y = y;
        this.name = name;
    }
 
    Point(String name){
        this.name = name;
        this.x = this.y = 0;
    }
 
    public double distance() {
        return Math.sqrt(x*x + y*y);
    }
 
    public void resetPoint() {
        x = 0;
        y = 0;
    }
 
    public void movePoint(int a, int b){
        x += a;
        y += b;
    }
 
    public String toString() {
        return name + "=(" + x + ", " + y + ")";
    }
}
 
